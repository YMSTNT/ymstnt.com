---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BlogPost from "../../components/BlogPost.astro";
import CenteredBody from "../../components/CenteredBody.astro";

export async function getStaticPaths() {
  const allPosts = (await getCollection("blog")) || [];

  allPosts.sort(
    (a, b) => Date.parse(b.data.published) - Date.parse(a.data.published)
  );

  const uniqueTags = [
    ...new Set(allPosts.map((post) => post.data.tags).flat()),
  ];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) =>
      post.data.tags.includes(tag)
    );
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Layout title="TNT's Blog" description={`Posts tagged as ${tag}`} nav="/blog">
  <main>
    <h2 id="intro">Posts tagged with <span id="highlight">{tag}</span>:</h2>
    <div id="article-list" class="col-65 left">
      {
        posts.length > 0 ? (
          <div id="article-list">
            {posts
              .sort((a, b) => +b.data.published - +a.data.published)
              .map(({ data, slug }) => (
                <BlogPost
                  url={`/blog/${slug}/`}
                  title={data.title}
                  description={data.description}
                  date={data.published}
                  tags={data.tags}
                />
              ))}
          </div>
        ) : (
          <h1 id="none">No posts available.</h1>
        )
      }
    </div>
  </main>
</Layout>

<style>
  #intro {
    margin-bottom: 1em;
  }

  #highlight {
    color: var(--subtext0);
  }

  main {
    flex-direction: column;
    max-width: 64rem;
    width 100%;
    align-self: center;
    padding: 0 2.5rem;
    margin: 0 auto;
  }

  #article-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 500px) {
    body {
      font-size: 1em;
    }
    main {
      padding: 1.5em;
    }
  }
</style>
