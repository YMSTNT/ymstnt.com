---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import CenteredCard from "../components/CenteredCard.astro";
---

<Layout title="404 Not Found" description="Page not found">
  <!-- <Navbar /> -->
  <CenteredCard maxWidth="30em">
    <h1>404</h1>
    <h3>That page was not found.</h3>
    <p>
      You may have followed a broken link or this part of the site is under
      construction.
    </p>
    <p>Either way, click the button to get back home!</p>
    <a href="/"
      ><div id="homebtn-container">
        <h3>Home</h3>
      </div>
    </a>
  </CenteredCard>
</Layout>

<style>
  h1 {
    font-size: 1.5em;
    margin-block-start: 0.83em;
    margin-block-end: 0.83em;
  }

  #homebtn-container {
    padding: 2px;
    border-radius: 0.5em;
    min-width: 7em;
    margin: 0 7em;
    cursor: pointer;
    position: relative;
    transition: all 0.15s ease;
  }

  #homebtn-container:hover {
  }

  @media screen and (max-width: 800px) {
    body {
      font-size: 1em;
    }
    main {
      padding: 1.5em;
    }
    #homebtn-container {
      margin: 0 5em;
    }
  }

  @media screen and (max-width: 400px) {
    #homebtn-container {
      margin: 0;
    }
  }
</style>
