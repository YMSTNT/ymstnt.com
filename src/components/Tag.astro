---
import "../styles/global.css";

const { isCompact, isDisplayOnly } = Astro.props;
---

<tag
  id="tag"
  class:list={[{ compact: isCompact }, { displayOnly: isDisplayOnly }]}
>
  <slot />
</tag>

<style>
  #tag {
    display: inline-block;
    border: var(--card-border) 1px solid;
    /* margin-right: 0.5rem; */
    /* margin-bottom: 0.5rem; */
    padding: 0.25rem 0.5rem;
    border-radius: 5rem;
    cursor: pointer;
    /* position: relative; */
    color: var(--subtext0);
    line-height: 1.7em;
    background-color: transparent;
    transition: all 0.2s ease-in-out;
  }

  #tag:hover:not(.displayOnly),
  #tag:active:not(.displayOnly) {
    background-color: var(--card-border);
    color: var(--bg);
    /* border: var(--link-hover) 1px solid; */
  }

  /* .ref {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: 1;
  } */

  .compact {
    border: unset;
    margin-top: 0.2rem;
  }

  .displayOnly {
    /* border: unset !important; */
    cursor: unset !important;
    transition: unset !important;
  }
</style>
