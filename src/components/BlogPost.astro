---
import "../styles/global.css";
import Tag from "./Tag.astro";

const { title, url, description, date, tags } = Astro.props;

const dateOptions: object = {
  year: "numeric",
  month: "long",
  day: "numeric",
};

const formattedPublishDate = new Date(date).toLocaleDateString(
  "en-US",
  dateOptions
);
---

<article>
  <a href={url}>
    <h2 class="title">{title}</h2>
    <h2 class="date">{formattedPublishDate}</h2>
    <div id="tags">
      {
        tags.map((tag) => (
          <Tag isDisplayOnly isCompact>
            #{tag}
          </Tag>
        ))
      }
    </div>
    <p>{description}</p>
  </a>
</article>
